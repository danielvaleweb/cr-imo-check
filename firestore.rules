rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Funções de Autenticação e Admin
    // ===============================================================
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "xgp4kEuc66UbGXIMcBVAa4fykus2" ||
        request.auth.token.get('email', '').toLower() == "danielvaleweb@gmail.com"
      );
    }

    // ===============================================================
    // Coleção de Usuários e Aprovação
    // ===============================================================

    match /users/{userId} {
      // PERMISSÃO DE LEITURA TOTAL PARA LOGADOS (Evita erro no Header e Dashboard)
      allow read: if request.auth != null;
      
      // PERMISSÃO DE CRIAÇÃO (Permite que qualquer pessoa se cadastre usando qualquer email)
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // PERMISSÃO DE ATUALIZAÇÃO (Permite que o usuário edite o perfil ou o Admin aprove)
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      
      // PERMISSÃO DE EXCLUSÃO (Apenas Admin)
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Leads e Propostas (Protegidos, mas permitem criação pública)
    // ===============================================================

    match /property_leads/{id} {
      allow read, write: if isAdmin();
      allow create: if true; 
    }

    match /proposals/{id} {
      allow read, write: if isAdmin();
      allow create: if true;
    }

    // ===============================================================
    // Conteúdo do Site (Público para leitura)
    // ===============================================================

    match /properties/{id} { allow read: if true; allow write: if isAdmin(); }
    match /brokers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /condos/{id} { allow read: if true; allow write: if isAdmin(); }
    match /system_config/{id} { allow read: if true; allow write: if isAdmin(); }
    match /condo_options/{id} { allow read: if true; allow write: if isAdmin(); }

    // ===============================================================
    // Backup e Segurança Final
    // ===============================================================

    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}

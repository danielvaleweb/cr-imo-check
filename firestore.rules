rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Funções Auxiliares (Helper Functions)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Função de Admin ultra-robusta e prioritária
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.uid == "xgp4kEuc66UbGXIMcBVAa4fykus2" ||
        (request.auth.token != null && "email" in request.auth.token && request.auth.token.email.lower() == "danielvaleweb@gmail.com")
      );
    }

    // ===============================================================
    // Coleções Críticas do Dashboard (Admin Key Access)
    // ===============================================================

    match /property_leads/{id} {
      allow get, list, write: if isAdmin();
      allow create: if true;
    }

    match /proposals/{id} {
      allow get, list, write: if isAdmin();
      allow create: if true;
    }

    match /users/{userId} {
      allow get, list, write: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // ===============================================================
    // Coleções Públicas e de Sistema
    // ===============================================================

    match /properties/{id} { allow read: if true; allow write: if isAdmin(); }
    match /brokers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /condos/{id} { allow read: if true; allow write: if isAdmin(); }
    match /system_config/{id} { allow read: if true; allow write: if isAdmin(); }
    match /condo_options/{id} { allow read: if true; allow write: if isAdmin(); }

    // Backup Geral para Admin (Catch-all)
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
